{
  "name": "lkps-app",
  "version": "1.0.0",
  "description": "LORD KRISHNA PUBLIC SCHOOL — Full Stack App",
  "private": true,
  "scripts": {
    "server": "npm start --prefix server",
    "client": "npm start --prefix client",
    "mobile": "npm start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:ios": "npm run ios --prefix mobile",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "install:all": "npm install --prefix server && npm install --prefix client && npm install --prefix mobile"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
